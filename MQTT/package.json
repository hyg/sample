{
  "name": "mqtt-e2ee-chat",
  "version": "1.0.0",
  "description": "E2EE MQTT chat tool with multi-DID support (did:key, did:ethr, extensible)",
  "type": "module",
  "main": "src/cli.js",
  "scripts": {
    "start:cli": "node src/cli.js",
    "start:trustee": "node src/cli.js --role trustee",
    "start:delegator": "node src/cli.js --role delegator",
    "serve": "npx http-server -p 8080 -c-1"
  },
  "keywords": [
    "mqtt",
    "e2ee",
    "did",
    "chat",
    "encryption",
    "did-key",
    "did-ethr",
    "hpke"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@noble/curves": "^1.3.0",
    "@noble/hashes": "^1.3.3",
    "@panva/hpke-noble": "^1.0.6",
    "hpke": "^1.0.6",
    "mqtt": "^5.3.0",
    "uuid": "^9.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
