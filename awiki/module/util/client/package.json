{
  "name": "@awiki/client",
  "version": "1.0.0",
  "description": "HTTP client factory for awiki SDK (ported from python/scripts/utils/client.py)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rimraf dist",
    "prebuild": "npm run clean",
    "test": "node --experimental-vm-modules --test tests/*.test.js",
    "test:coverage": "node --experimental-vm-modules --test --test-reporter=spec --test-reporter-destination=stdout tests/*.test.js"
  },
  "keywords": [
    "awiki",
    "http",
    "client",
    "sdk"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "rimraf": "^6.0.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
