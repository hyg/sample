{
  "name": "@awiki/identity",
  "version": "1.0.0",
  "description": "DID Identity creation module for awiki - TypeScript port of python/scripts/utils/identity.py",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "del /Q dist",
    "prebuild": "npm run clean",
    "test": "node --test test/*.test.js"
  },
  "keywords": [
    "did",
    "identity",
    "wba",
    "secp256k1",
    "awiki"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@awiki/anp-auth": "file:../anp-auth"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "@types/node": "^20.0.0"
  }
}
