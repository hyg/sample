{
  "name": "@awiki/ws",
  "version": "1.0.0",
  "description": "WebSocket client for awiki SDK (ported from python/scripts/utils/ws.py)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rimraf dist",
    "prebuild": "npm run clean",
    "test": "node --test test/*.test.js"
  },
  "keywords": [
    "awiki",
    "websocket",
    "client",
    "sdk"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@awiki/client": "file:../client",
    "@awiki/config": "file:../config",
    "@types/ws": "^8.5.0",
    "ws": "^8.14.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "rimraf": "^6.0.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
