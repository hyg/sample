{
  "name": "@awiki/e2ee",
  "version": "1.0.0",
  "description": "E2EE end-to-end encryption client for awiki - TypeScript port of python/scripts/utils/e2ee.py",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rmdir /Q /S dist",
    "prebuild": "npm run clean",
    "test": "node --test test/*.test.js"
  },
  "keywords": [
    "e2ee",
    "encryption",
    "hpke",
    "x25519",
    "did",
    "awiki"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@awiki/anp-auth": "file:../anp-auth",
    "@awiki/resolve": "file:../resolve",
    "@noble/curves": "^1.9.7",
    "@noble/hashes": "^1.8.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.0.0"
  }
}
