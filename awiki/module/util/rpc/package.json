{
  "name": "@awiki/rpc",
  "version": "1.0.0",
  "description": "JSON-RPC 2.0 client for awiki - TypeScript port of python/scripts/utils/rpc.py",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "del /Q dist",
    "prebuild": "npm run clean",
    "test": "node --test test/*.test.js"
  },
  "keywords": [
    "json-rpc",
    "rpc",
    "client",
    "awiki"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.0.0",
    "@types/node": "^20.0.0"
  },
  "dependencies": {
    "@awiki/client": "file:../client"
  }
}
