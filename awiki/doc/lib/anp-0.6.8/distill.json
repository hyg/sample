  "integration_flows": [
    {
      "id": "FLOW-001",
      "name": "用户注册流程",
      "steps": [
        {
          "step": 1,
          "action": "create_did_wba_document_with_key_binding",
          "description": "生成密钥对和 DID 文档（含 authentication proof）"
        },
        {
          "step": 2,
          "action": "generate_auth_header",
          "description": "使用生成的 DID 文档创建认证头"
        },
        {
          "step": 3,
          "action": "RPC call: did-auth.register",
          "description": "发送 DID 文档到服务器进行注册"
        }
      ]
    },
    {
      "id": "FLOW-002",
      "name": "E2EE 会话建立流程",
      "steps": [
