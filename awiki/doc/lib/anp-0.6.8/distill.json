      "input": {
        "content": {
          "e2ee_version": "1.1",
          "session_id": "session_abc123",
          "sender_did": "did:wba:awiki.ai:user:k1_sender",
          "recipient_did": "did:wba:awiki.ai:user:k1_receiver",
          "sender_key_id": "did:wba:awiki.ai:user:k1_sender#key-3",
          "expires": 86400,
