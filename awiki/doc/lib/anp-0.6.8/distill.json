      "error_scenarios": [
        {
          "condition": "proof 验证失败",
          "expected_error": "ValueError: proof verification failed"
        },
        {
          "condition": "e2ee_version 不匹配",
          "expected_error": "ValueError: unsupported e2ee_version"
        },
        {
          "condition": "proof 过期",
