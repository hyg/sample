        }
      ]
    },
    {
      "id": "TC-E2EE-003",
      "module": "anp.e2e_encryption_hpke",
      "class": "E2eeHpkeSession",
      "method": "encrypt_message",
      "source_file": "utils/e2ee.py",
      "wrapper_function": "encrypt_message",
      "business_scenario": "使用 HPKE 加密消息（Chain Ratchet 前向安全）",
      "input": {
        "original_type": "text",
        "plaintext": "Hello, this is a secret message!"
      },
      "expected_output": {
        "type": "tuple",
        "structure": "(msg_type: str, content: dict)",
        "msg_type": "e2ee_msg",
        "content": {
          "e2ee_version": "1.1",
          "session_id": "session_abc123",
          "original_type": "text",
          "ciphertext": "<base64_encoded_encrypted_data>",
          "seq": 0
        }
      },
      "error_scenarios": [
        {
          "condition": "会话已过期",
          "expected_error": "RuntimeError: session expired"
        },
        {
          "condition": "会话未激活",
          "expected_error": "RuntimeError: session not active"
        }
      ]
    },
