    {
      "id": "TC-E2EE-001",
      "module": "anp.e2e_encryption_hpke",
      "class": "E2eeHpkeSession",
      "method": "initiate_session",
      "source_file": "utils/e2ee.py",
      "wrapper_function": "initiate_handshake",
      "business_scenario": "发起 E2EE 会话（发送 e2ee_init）",
      "input": {
        "local_did": "did:wba:awiki.ai:user:k1_local_user",
        "peer_did": "did:wba:awiki.ai:user:k1_peer_user",
        "local_x25519_private_key": "<X25519PrivateKey object>",
        "local_x25519_key_id": "did:wba:awiki.ai:user:k1_local_user#key-3",
        "signing_private_key": "<secp256r1 PrivateKey object>",
        "signing_verification_method": "did:wba:awiki.ai:user:k1_local_user#key-2",
        "peer_public_key": "<X25519PublicKey object>",
        "peer_key_id": "did:wba:awiki.ai:user:k1_peer_user#key-3"
      },
      "expected_output": {
        "type": "tuple",
        "structure": "(msg_type: str, content: dict)",
        "msg_type": "e2ee_init",
        "content": {
          "e2ee_version": "1.1",
          "session_id": "<unique_session_id>",
          "sender_did": "did:wba:awiki.ai:user:k1_local_user",
          "recipient_did": "did:wba:awiki.ai:user:k1_peer_user",
          "sender_key_id": "did:wba:awiki.ai:user:k1_local_user#key-3",
          "recipient_key_id": "did:wba:awiki.ai:user:k1_peer_user#key-3",
          "expires": 86400,
          "proof": {
            "type": "E2eeProof2025",
            "verificationMethod": "did:wba:awiki.ai:user:k1_local_user#key-2",
            "created": "2026-03-16T10:00:00Z",
            "proofValue": "z..."
          }
        }
      },
      "error_scenarios": [
        {
          "condition": "peer_public_key 为 None",
          "expected_error": "ValueError: peer_public_key is required"
        }
      ]
    },
    {
      "id": "TC-E2EE-002",
      "module": "anp.e2e_encryption_hpke",
      "class": "E2eeHpkeSession",
