  "captured_params": {
    "endpoint": "/search/rpc",
    "method": "search.users",
    "params": {
      "type": "keyword",
      "q": "alice"
    }
  },
  "expected": {
    "endpoint": "/search/rpc",
    "method": "search.users",
    "params": {
      "type": "keyword",
      "q": "alice"
    }
  }
}

============================================================
【验证结果】
============================================================
✓ 参数构造正确

============================================================
【测试 2: 凭证缺失处理】
