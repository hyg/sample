{
  "file": "python/scripts/utils/auth.py",
  "analysis_date": "2026-03-16",
  "module": "auth",
  "description": "DID WBA 认证模块 - 注册、文档更新、JWT 获取、一站式身份创建",
  "test_cases": [
    {
      "id": "TC-AUTH-001",
      "function": "generate_wba_auth_header",
      "scenario": "DID WBA 认证头生成 - 正常场景",
      "description": "使用有效的 DIDIdentity 和服务域名生成认证头",
      "input": {
        "identity": "有效的 DIDIdentity 对象（包含私钥和 DID 文档）",
        "service_domain": "awiki.ai"
      },
      "expected_output": {
        "type": "str",
        "format": "DIDWba <signature_data>",
        "contains": ["DIDWba", "签名数据"]
      },
      "assertions": [
        "返回值以 'DIDWba ' 开头",
        "返回值长度大于 10",
        "相同输入产生相同输出（确定性签名）"
      ]
    },
    {
      "id": "TC-AUTH-002",
      "function": "generate_wba_auth_header",
      "scenario": "DID WBA 认证头生成 - 不同域名",
      "description": "验证不同服务域名生成不同的认证头",
      "input": {
        "identity": "同一个 DIDIdentity 对象",
        "service_domain": ["awiki.ai", "test.awiki.ai", "localhost"]
      },
      "expected_output": {
        "type": "str",
        "format": "不同域名产生不同的签名头"
      },
      "assertions": [
        "不同域名产生的认证头不同",
        "每个认证头都符合 DIDWba 格式"
      ]
    },
    {
      "id": "TC-AUTH-003",
      "function": "generate_wba_auth_header",
      "scenario": "DID WBA 认证头生成 - 私钥缺失",
      "description": "当 identity 没有私钥时的错误处理",
      "input": {
        "identity": "只包含公钥的 DIDIdentity 对象（无私钥）",
        "service_domain": "awiki.ai"
      },
      "expected_output": {
        "type": "exception",
        "exception_type": "AttributeError 或 ValueError"
      },
      "assertions": [
        "抛出适当的异常",
        "异常信息说明私钥缺失"
      ]
    },
    {
      "id": "TC-AUTH-004",
      "function": "register_did",
      "scenario": "DID 注册 - 最小参数注册",
      "description": "仅使用必需的 identity 参数进行注册",
      "input": {
        "client": "配置正确的 httpx.AsyncClient",
        "identity": "有效的 DIDIdentity 对象",
        "name": null,
        "is_public": false,
        "is_agent": false,
        "role": null,
        "endpoint_url": null,
        "description": null
      },
      "expected_output": {
        "type": "dict",
        "keys": ["did", "user_id", "message"]
      },
      "assertions": [
        "返回 dict 包含 'did' 键",
        "返回 dict 包含 'user_id' 键",
        "返回 dict 包含 'message' 键",
        "did 与 identity.did 一致"
      ]
    },
    {
      "id": "TC-AUTH-005",
      "function": "register_did",
      "scenario": "DID 注册 - 完整参数注册",
      "description": "使用所有可选参数进行注册",
      "input": {
        "client": "配置正确的 httpx.AsyncClient",
        "identity": "有效的 DIDIdentity 对象",
        "name": "测试用户",
        "is_public": true,
        "is_agent": false,
        "role": "user",
        "endpoint_url": "https://example.com/endpoint",
        "description": "测试描述"
      },
      "expected_output": {
        "type": "dict",
        "keys": ["did", "user_id", "message"]
      },
      "assertions": [
        "注册成功返回 user_id",
        "服务端收到所有可选参数"
      ]
    },
    {
      "id": "TC-AUTH-006",
      "function": "register_did",
      "scenario": "DID 注册 - Agent 身份注册",
      "description": "注册 AI Agent 身份",
      "input": {
        "client": "配置正确的 httpx.AsyncClient",
        "identity": "有效的 DIDIdentity 对象",
        "name": "测试 Agent",
        "is_public": true,
        "is_agent": true,
        "role": "assistant",
        "endpoint_url": "https://agent.example.com/rpc"
      },
      "expected_output": {
        "type": "dict",
        "keys": ["did", "user_id", "message"]
      },
      "assertions": [
        "is_agent 标志被正确设置",
        "返回的 user_id 有效"
      ]
    },
    {
      "id": "TC-AUTH-007",
      "function": "register_did",
      "scenario": "DID 注册 - 重复注册",
      "description": "尝试注册已存在的 DID",
      "input": {
        "client": "配置正确的 httpx.AsyncClient",
        "identity": "已注册过的 DIDIdentity 对象"
      },
      "expected_output": {
        "type": "exception",
        "exception_type": "JsonRpcError"
      },
      "assertions": [
        "抛出 JsonRpcError",
        "错误码表示已存在",
        "错误信息说明 DID 已注册"
      ]
    },
    {
      "id": "TC-AUTH-008",
      "function": "register_did",
      "scenario": "DID 注册 - 网络错误",
      "description": "客户端无法连接服务端时的错误处理",
      "input": {
        "client": "指向无效地址的 httpx.AsyncClient",
        "identity": "有效的 DIDIdentity 对象"
      },
      "expected_output": {
        "type": "exception",
        "exception_type": "httpx.ConnectError 或 httpx.HTTPStatusError"
      },
      "assertions": [
        "抛出网络相关异常"
      ]
    },
    {
      "id": "TC-AUTH-009",
      "function": "update_did_document",
      "scenario": "DID 文档更新 - 正常更新",
      "description": "更新现有 DID 文档",
      "input": {
        "client": "配置正确的 httpx.AsyncClient",
        "identity": "已注册的 DIDIdentity 对象（文档已更新）",
        "domain": "awiki.ai",
        "is_public": true,
        "is_agent": false,
        "role": "premium_user",
        "endpoint_url": "https://new-endpoint.com"
      },
      "expected_output": {
        "type": "dict",
        "keys": ["did", "user_id", "message"]
      },
      "assertions": [
        "更新成功返回 user_id",
        "文档被正确更新",
        "可能包含 access_token"
      ]
    },
    {
      "id": "TC-AUTH-010",
      "function": "update_did_document",
      "scenario": "DID 文档更新 - 从响应头获取 access_token",
      "description": "当服务端在 Authorization 响应头返回 token 时",
      "input": {
        "client": "配置正确的 httpx.AsyncClient",
        "identity": "已注册的 DIDIdentity 对象",
        "domain": "awiki.ai"
      },
      "expected_output": {
        "type": "dict",
        "keys": ["did", "user_id", "message", "access_token"]
      },
      "assertions": [
        "result 包含 access_token",
        "access_token 来自响应头 Authorization: Bearer xxx"
      ]
    },
    {
      "id": "TC-AUTH-011",
      "function": "update_did_document",
      "scenario": "DID 文档更新 - 未授权的 DID",
      "description": "尝试更新不属于自己的 DID",
      "input": {
        "client": "配置正确的 httpx.AsyncClient",
        "identity": "未注册的或他人的 DIDIdentity 对象",
        "domain": "awiki.ai"
      },
      "expected_output": {
        "type": "exception",
        "exception_type": "JsonRpcError"
      },
      "assertions": [
        "抛出 JsonRpcError",
        "错误码表示未授权"
      ]
    },
    {
      "id": "TC-AUTH-012",
      "function": "update_did_document",
      "scenario": "DID 文档更新 - 认证头生成失败",
      "description": "当 generate_wba_auth_header 失败时",
      "input": {
        "client": "配置正确的 httpx.AsyncClient",
        "identity": "私钥无效的 DIDIdentity 对象",
        "domain": "awiki.ai"
      },
      "expected_output": {
        "type": "exception",
        "exception_type": "签名相关异常"
      },
      "assertions": [
        "在发送请求前抛出异常"
      ]
    },
    {
      "id": "TC-AUTH-013",
      "function": "get_jwt_via_wba",
      "scenario": "JWT 获取 - 正常获取",
      "description": "通过 WBA 签名成功获取 JWT",
      "input": {
        "client": "配置正确的 httpx.AsyncClient",
        "identity": "已注册的 DIDIdentity 对象",
        "domain": "awiki.ai"
      },
      "expected_output": {
        "type": "str",
        "format": "JWT token (三段式 base64url 编码)"
      },
      "assertions": [
        "返回值是字符串",
        "包含两个 '.' 字符（JWT 格式）",
        "长度大于 50"
      ]
    },
    {
      "id": "TC-AUTH-014",
      "function": "get_jwt_via_wba",
      "scenario": "JWT 获取 - 未注册的 DID",
      "description": "尝试为未注册的 DID 获取 JWT",
      "input": {
        "client": "配置正确的 httpx.AsyncClient",
        "identity": "未注册的 DIDIdentity 对象",
        "domain": "awiki.ai"
      },
      "expected_output": {
        "type": "exception",
        "exception_type": "JsonRpcError"
      },
      "assertions": [
        "抛出 JsonRpcError",
        "错误信息说明 DID 未找到"
      ]
    },
    {
      "id": "TC-AUTH-015",
      "function": "get_jwt_via_wba",
      "scenario": "JWT 获取 - 签名验证失败",
      "description": "使用错误的私钥签名导致验证失败",
      "input": {
        "client": "配置正确的 httpx.AsyncClient",
        "identity": "私钥与 DID 文档不匹配的 DIDIdentity 对象",
        "domain": "awiki.ai"
      },
      "expected_output": {
        "type": "exception",
        "exception_type": "JsonRpcError"
      },
      "assertions": [
        "抛出 JsonRpcError",
        "错误信息说明签名验证失败"
      ]
    },
    {
      "id": "TC-AUTH-016",
      "function": "get_jwt_via_wba",
      "scenario": "JWT 获取 - 响应格式异常",
      "description": "服务端返回的响应不包含 access_token",
      "input": {
        "client": "配置正确的 httpx.AsyncClient（mock 返回不含 access_token 的响应）",
        "identity": "已注册的 DIDIdentity 对象",
        "domain": "awiki.ai"
      },
      "expected_output": {
        "type": "exception",
        "exception_type": "KeyError"
      },
      "assertions": [
        "抛出 KeyError 或类似异常",
        "异常指向 'access_token' 键"
      ]
    },
    {
      "id": "TC-AUTH-017",
      "function": "create_authenticated_identity",
      "scenario": "一站式身份创建 - 完整流程成功",
      "description": "从密钥生成到 JWT 获取的完整流程",
      "input": {
        "client": "配置正确的 httpx.AsyncClient",
        "config": "SDKConfig(did_domain='awiki.ai')",
        "name": "完整测试用户",
        "is_public": true,
        "is_agent": false,
        "role": "tester",
        "endpoint_url": null,
        "services": null
      },
      "expected_output": {
        "type": "DIDIdentity",
        "properties": {
          "did": "did:wba:awiki.ai:user:k1_...",
          "user_id": "有效的 UUID",
          "jwt_token": "有效的 JWT token"
        }
      },
      "assertions": [
        "返回 DIDIdentity 对象",
        "user_id 已设置（非 None）",
        "jwt_token 已设置（非 None）",
        "did 格式正确"
      ]
    },
    {
      "id": "TC-AUTH-018",
      "function": "create_authenticated_identity",
      "scenario": "一站式身份创建 - Agent 身份",
      "description": "创建 AI Agent 的完整认证身份",
      "input": {
        "client": "配置正确的 httpx.AsyncClient",
        "config": "SDKConfig(did_domain='awiki.ai')",
        "name": "测试 Agent",
        "is_public": true,
        "is_agent": true,
        "role": "assistant",
        "endpoint_url": "https://agent.example.com"
      },
      "expected_output": {
        "type": "DIDIdentity",
        "properties": {
          "did": "did:wba:awiki.ai:user:k1_...",
          "user_id": "有效的 UUID",
          "jwt_token": "有效的 JWT token"
        }
      },
      "assertions": [
        "Agent 身份创建成功",
        "user_id 和 jwt_token 都已设置"
      ]
    },
    {
      "id": "TC-AUTH-019",
      "function": "create_authenticated_identity",
      "scenario": "一站式身份创建 - 自定义服务",
      "description": "使用自定义 services 列表创建身份",
      "input": {
        "client": "配置正确的 httpx.AsyncClient",
        "config": "SDKConfig(did_domain='awiki.ai')",
        "services": [
          {
            "id": "#messaging",
            "type": "MessagingService",
            "serviceEndpoint": "https://messaging.example.com"
          }
        ]
      },
      "expected_output": {
        "type": "DIDIdentity",
        "properties": {
          "did": "did:wba:awiki.ai:user:k1_...",
          "user_id": "有效的 UUID",
          "jwt_token": "有效的 JWT token",
          "did_document": "包含自定义服务"
        }
      },
      "assertions": [
        "DID 文档包含自定义服务",
        "服务被正确签名"
      ]
    },
    {
      "id": "TC-AUTH-020",
      "function": "create_authenticated_identity",
      "scenario": "一站式身份创建 - 注册失败回滚",
      "description": "当注册步骤失败时的错误处理",
      "input": {
        "client": "配置正确的 httpx.AsyncClient（mock 注册失败）",
        "config": "SDKConfig(did_domain='awiki.ai')",
        "name": "测试用户"
      },
      "expected_output": {
        "type": "exception",
        "exception_type": "JsonRpcError"
      },
      "assertions": [
        "抛出注册失败的异常",
        "不会执行到 JWT 获取步骤"
      ]
    },
    {
      "id": "TC-AUTH-021",
      "function": "create_authenticated_identity",
      "scenario": "一站式身份创建 - JWT 获取失败",
      "description": "当 JWT 获取步骤失败时的错误处理",
      "input": {
        "client": "配置正确的 httpx.AsyncClient（mock JWT 获取失败）",
        "config": "SDKConfig(did_domain='awiki.ai')",
        "name": "测试用户"
      },
      "expected_output": {
        "type": "exception",
        "exception_type": "JsonRpcError 或 KeyError"
      },
      "assertions": [
        "抛出 JWT 获取失败的异常",
        "identity.user_id 已设置但 jwt_token 未设置"
      ]
    },
    {
      "id": "TC-AUTH-022",
      "function": "_secp256k1_sign_callback",
      "scenario": "签名回调 - 正常签名",
      "description": "验证 secp256k1 签名回调函数",
      "input": {
        "private_key": "有效的 secp256k1 私钥",
        "content": "待签名的字节数据",
        "verification_method_fragment": "验证方法片段（如 'k1_abc123'）"
      },
      "expected_output": {
        "type": "bytes",
        "format": "DER 编码的签名"
      },
      "assertions": [
        "返回字节类型",
        "签名长度符合 DER 编码规范（约 70-72 字节）",
        "相同内容产生相同签名"
      ]
    },
    {
      "id": "TC-AUTH-023",
      "function": "_secp256k1_sign_callback",
      "scenario": "签名回调 - 空内容签名",
      "description": "对空字节内容进行签名",
      "input": {
        "private_key": "有效的 secp256k1 私钥",
        "content": "b''",
        "verification_method_fragment": "k1_test"
      },
      "expected_output": {
        "type": "bytes",
        "format": "DER 编码的签名"
      },
      "assertions": [
        "空内容也能成功签名",
        "返回有效的 DER 编码签名"
      ]
    },
    {
      "id": "TC-AUTH-024",
      "function": "generate_wba_auth_header",
      "scenario": "DID WBA 认证头 - 验证回调被调用",
      "description": "验证 sign_callback 被正确调用",
      "input": {
        "identity": "有效的 DIDIdentity 对象",
        "service_domain": "awiki.ai"
      },
      "expected_output": {
        "type": "str",
        "format": "DIDWba 头"
      },
      "assertions": [
        "_secp256k1_sign_callback 被调用",
        "传入正确的 content 和 verification_method_fragment"
      ]
    },
    {
      "id": "TC-AUTH-025",
      "function": "update_did_document",
      "scenario": "DID 文档更新 - HTTP 状态码错误",
      "description": "服务端返回非 200 状态码时的处理",
      "input": {
        "client": "配置正确的 httpx.AsyncClient（mock 返回 500 错误）",
        "identity": "已注册的 DIDIdentity 对象",
        "domain": "awiki.ai"
      },
      "expected_output": {
        "type": "exception",
        "exception_type": "httpx.HTTPStatusError"
      },
      "assertions": [
        "抛出 HTTPStatusError",
        "包含正确的状态码信息"
      ]
    }
