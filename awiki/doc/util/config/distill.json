{
  "module": "python/scripts/utils/config.py",
  "description": "SDK 配置模块测试用例 - 凭证目录、数据目录、SDK 配置加载、环境变量覆盖",
  "test_cases": [
    {
      "id": "TC001",
      "name": "凭证目录解析 - 默认路径",
      "scenario": "凭证目录解析",
      "description": "验证 _default_credentials_dir() 返回正确的默认路径",
      "precondition": "无环境变量干扰",
      "steps": [
        "调用 _default_credentials_dir()",
        "验证返回路径格式"
      ],
      "expected": "Path('C:/Users/hyg/.openclaw/credentials/awiki-agent-id-message')",
      "assertions": [
        "返回类型为 pathlib.Path",
        "路径以 ~/.openclaw/credentials/awiki-agent-id-message 结尾"
      ]
    },
    {
      "id": "TC002",
      "name": "数据目录解析 - AWIKI_DATA_DIR 优先级最高",
      "scenario": "数据目录解析",
      "description": "验证 AWIKI_DATA_DIR 环境变量直接覆盖数据目录",
      "precondition": "设置 AWIKI_DATA_DIR=/custom/data/path",
      "steps": [
        "设置环境变量 AWIKI_DATA_DIR=/custom/data/path",
        "调用 _default_data_dir()",
        "验证返回路径"
      ],
      "expected": "Path('/custom/data/path')",
      "assertions": [
        "返回路径等于 AWIKI_DATA_DIR 的值",
        "忽略 AWIKI_WORKSPACE 和默认路径"
      ]
    },
    {
      "id": "TC003",
      "name": "数据目录解析 - AWIKI_WORKSPACE 次优先级",
      "scenario": "数据目录解析",
      "description": "验证 AWIKI_WORKSPACE 环境变量在无 AWIKI_DATA_DIR 时生效",
      "precondition": "AWIKI_DATA_DIR 未设置，AWIKI_WORKSPACE=/my/workspace",
      "steps": [
        "确保 AWIKI_DATA_DIR 未设置",
        "设置 AWIKI_WORKSPACE=/my/workspace",
        "调用 _default_data_dir()",
        "验证返回路径"
      ],
      "expected": "Path('/my/workspace/data/awiki-agent-id-message')",
      "assertions": [
        "返回路径包含 AWIKI_WORKSPACE 值",
        "路径包含 /data/awiki-agent-id-message 后缀"
      ]
    },
    {
      "id": "TC004",
      "name": "数据目录解析 - 默认路径回退",
      "scenario": "数据目录解析",
      "description": "验证无任何环境变量时使用默认路径",
      "precondition": "AWIKI_DATA_DIR 和 AWIKI_WORKSPACE 均未设置",
      "steps": [
        "确保 AWIKI_DATA_DIR 未设置",
        "确保 AWIKI_WORKSPACE 未设置",
        "调用 _default_data_dir()",
        "验证返回路径"
      ],
      "expected": "Path('C:/Users/hyg/.openclaw/workspace/data/awiki-agent-id-message')",
      "assertions": [
        "返回默认路径 ~/.openclaw/workspace/data/awiki-agent-id-message"
      ]
    },
    {
      "id": "TC005",
      "name": "SDK 配置加载 - 默认值",
      "scenario": "SDK 配置加载",
      "description": "验证 SDKConfig 使用默认值初始化",
      "precondition": "无环境变量，无 settings.json 文件",
      "steps": [
        "确保无相关环境变量",
        "确保 settings.json 不存在",
        "调用 SDKConfig()",
        "验证各字段默认值"
      ],
      "expected": {
        "user_service_url": "https://awiki.ai",
        "molt_message_url": "https://awiki.ai",
        "molt_message_ws_url": null,
        "did_domain": "awiki.ai"
      },
      "assertions": [
        "user_service_url 默认为 https://awiki.ai",
        "molt_message_url 默认为 https://awiki.ai",
        "molt_message_ws_url 默认为 None",
        "did_domain 默认为 awiki.ai"
      ]
    },
    {
      "id": "TC006",
      "name": "SDK 配置加载 - settings.json 文件配置",
      "scenario": "SDK 配置加载",
      "description": "验证从 settings.json 文件加载配置",
      "precondition": "settings.json 存在且包含配置项",
      "steps": [
        "创建 settings.json 包含自定义配置",
        "确保无环境变量覆盖",
        "调用 SDKConfig.load()",
        "验证配置值来自文件"
      ],
      "expected": "配置值从 settings.json 读取",
      "assertions": [
        "user_service_url 来自文件配置",
        "molt_message_url 来自文件配置",
        "did_domain 来自文件配置"
      ]
    },
    {
      "id": "TC007",
      "name": "SDK 配置加载 - 环境变量覆盖文件配置",
      "scenario": "环境变量覆盖",
      "description": "验证环境变量优先级高于 settings.json",
      "precondition": "settings.json 存在，同时设置环境变量",
      "steps": [
        "创建 settings.json 包含 user_service_url=https://file.example.com",
        "设置 E2E_USER_SERVICE_URL=https://env.example.com",
        "调用 SDKConfig.load()",
        "验证配置值"
      ],
      "expected": "user_service_url=https://env.example.com",
      "assertions": [
        "环境变量值覆盖文件配置值",
        "优先级：环境变量 > settings.json > 默认值"
      ]
    },
    {
      "id": "TC008",
      "name": "SDK 配置加载 - 部分环境变量覆盖",
      "scenario": "环境变量覆盖",
      "description": "验证仅部分环境变量设置时的行为",
      "precondition": "仅设置 E2E_DID_DOMAIN 环境变量",
      "steps": [
        "创建 settings.json 包含完整配置",
        "仅设置 E2E_DID_DOMAIN=custom.domain.com",
        "调用 SDKConfig.load()",
        "验证各字段来源"
      ],
      "expected": {
        "did_domain": "custom.domain.com (来自环境变量)",
        "其他字段": "来自 settings.json"
      },
      "assertions": [
        "did_domain 使用环境变量值",
        "其他字段使用文件配置值"
      ]
    },
    {
      "id": "TC009",
      "name": "SDK 配置加载 - settings.json 不存在",
      "scenario": "SDK 配置加载",
      "description": "验证 settings.json 不存在时的回退行为",
      "precondition": "settings.json 文件不存在",
      "steps": [
        "确保 settings.json 不存在",
        "确保无环境变量",
        "调用 SDKConfig.load()",
        "验证使用默认值"
      ],
      "expected": "所有字段使用默认值",
      "assertions": [
        "不抛出异常",
        "credentials_dir 和 data_dir 使用默认路径",
        "服务 URL 使用默认值"
      ]
    },
    {
      "id": "TC010",
      "name": "SDK 配置 - dataclass 不可变性",
      "scenario": "SDK 配置加载",
      "description": "验证 SDKConfig 是 frozen dataclass，不可修改",
      "precondition": "已创建 SDKConfig 实例",
      "steps": [
        "创建 SDKConfig 实例",
        "尝试修改实例字段",
        "验证是否抛出异常"
      ],
      "expected": "抛出 FrozenInstanceError",
      "assertions": [
        "SDKConfig 实例不可修改",
        "修改字段时抛出异常"
      ]
    },
    {
      "id": "TC011",
      "name": "SDK 配置加载 - molt_message_ws_url 可为空",
      "scenario": "SDK 配置加载",
      "description": "验证 molt_message_ws_url 允许为 None",
      "precondition": "无 E2E_MOLT_MESSAGE_WS_URL 环境变量",
      "steps": [
        "确保 E2E_MOLT_MESSAGE_WS_URL 未设置",
        "确保 settings.json 中 molt_message_ws_url 不存在或为 null",
        "调用 SDKConfig.load()",
        "验证 molt_message_ws_url 为 None"
      ],
      "expected": "molt_message_ws_url = None",
      "assertions": [
        "molt_message_ws_url 可以为 None",
        "不设置默认值"
      ]
    },
    {
      "id": "TC012",
      "name": "SDK 配置加载 - 优先级完整验证",
      "scenario": "环境变量覆盖",
      "description": "完整验证优先级链：环境变量 > settings.json > 默认值",
      "precondition": "同时存在环境变量、文件配置和默认值",
      "steps": [
        "设置 E2E_USER_SERVICE_URL=https://env.com",
        "settings.json 包含 molt_message_url=https://file.com",
        "did_domain 使用默认值",
        "调用 SDKConfig.load()",
        "验证各字段来源"
      ],
      "expected": {
        "user_service_url": "https://env.com (环境变量)",
        "molt_message_url": "https://file.com (文件)",
        "did_domain": "awiki.ai (默认)"
      },
      "assertions": [
        "优先级机制正确工作",
        "各字段独立选择来源"
      ]
    }
  ],
  "coverage": {
    "functions": [
      "_default_credentials_dir()",
      "_default_data_dir()",
      "SDKConfig.__init__()",
      "SDKConfig.load()"
    ],
    "scenarios": [
      "凭证目录解析",
      "数据目录解析",
      "SDK 配置加载",
      "环境变量覆盖"
    ],
    "edge_cases": [
      "settings.json 不存在",
      "环境变量部分设置",
      "molt_message_ws_url 为 None",
      "frozen dataclass 不可变性"
    ]
  },
  "total_cases": 12,
  "created_date": "2026-03-16",
  "source_file": "D:\\huangyg\\git\\sample\\awiki\\python\\scripts\\utils\\config.py"
}
