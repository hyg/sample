{
  "module": "python/scripts/utils/identity.py",
  "description": "DID 身份创建模块测试用例 - 基于 ANP 封装的密钥绑定 DID 身份创建",
  "test_cases": [
    {
      "id": "TC-001",
      "name": "创建基础 DID 身份 - 默认参数",
      "scene": "DID 身份创建",
      "description": "使用默认参数创建基础 DID 身份，验证 secp256k1 密钥对和 DID 文档生成",
      "input": {
        "hostname": "awiki.ai",
        "path_prefix": null,
        "proof_purpose": "authentication",
        "domain": null,
        "challenge": null,
        "services": null
      },
      "expected_output": {
        "did_format": "did:wba:awiki.ai:user:k1_<fingerprint>",
        "did_document_has_id": true,
        "did_document_has_proof": true,
        "private_key_pem_type": "bytes",
        "public_key_pem_type": "bytes",
        "e2ee_keys_present": true
      },
      "assertions": [
        "result.did 以 'did:wba:awiki.ai:user:k1_' 开头",
        "result.did_document['id'] == result.did",
        "result.did_document 包含 'proof' 字段",
        "result.private_key_pem 是 bytes 类型且非空",
        "result.public_key_pem 是 bytes 类型且非空",
        "result.e2ee_signing_private_pem 非 None",
        "result.e2ee_agreement_private_pem 非 None"
      ]
    },
    {
      "id": "TC-002",
      "name": "创建 DID 身份 - 自定义路径前缀",
      "scene": "DID 身份创建",
      "description": "使用自定义路径前缀创建 agent 类型的 DID 身份",
      "input": {
        "hostname": "awiki.ai",
        "path_prefix": ["agent"],
        "proof_purpose": "authentication",
        "domain": null,
        "challenge": null,
        "services": null
      },
      "expected_output": {
        "did_format": "did:wba:awiki.ai:agent:k1_<fingerprint>"
      },
      "assertions": [
        "result.did 以 'did:wba:awiki.ai:agent:k1_' 开头",
        "result.unique_id == result.did.rsplit(':', 1)[-1]"
      ]
    },
    {
      "id": "TC-003",
      "name": "创建 DID 身份 - 自定义主机名",
      "scene": "DID 身份创建",
      "description": "使用本地测试主机名创建 DID 身份",
      "input": {
        "hostname": "localhost",
        "path_prefix": ["user"],
        "proof_purpose": "authentication",
        "domain": null,
        "challenge": null,
        "services": null
      },
      "expected_output": {
        "did_format": "did:wba:localhost:user:k1_<fingerprint>"
      },
      "assertions": [
        "result.did 以 'did:wba:localhost:user:k1_' 开头"
      ]
    },
    {
      "id": "TC-004",
      "name": "创建 DID 身份 - 带证明目的",
      "scene": "DID 身份创建",
      "description": "使用不同的 proof_purpose 创建 DID 身份",
      "input": {
        "hostname": "awiki.ai",
        "path_prefix": ["user"],
        "proof_purpose": "assertionMethod",
        "domain": null,
        "challenge": null,
        "services": null
      },
      "expected_output": {
        "did_document_has_proof": true,
        "proof_purpose": "assertionMethod"
      },
      "assertions": [
        "result.did_document['proof']['proofPurpose'] == 'assertionMethod'"
      ]
    },
    {
      "id": "TC-005",
      "name": "创建 DID 身份 - 带服务域名",
      "scene": "DID 身份创建",
      "description": "创建带服务域名绑定的 DID 身份，用于服务器验证",
      "input": {
        "hostname": "awiki.ai",
        "path_prefix": ["user"],
        "proof_purpose": "authentication",
        "domain": "https://awiki.ai",
        "challenge": null,
        "services": null
      },
      "expected_output": {
        "did_document_has_proof": true,
        "proof_domain": "https://awiki.ai"
      },
      "assertions": [
        "result.did_document['proof']['domain'] == 'https://awiki.ai'"
      ]
    },
    {
      "id": "TC-006",
      "name": "创建 DID 身份 - 自定义 challenge",
      "scene": "DID 身份创建",
      "description": "使用自定义 challenge 防止重放攻击",
      "input": {
        "hostname": "awiki.ai",
        "path_prefix": ["user"],
        "proof_purpose": "authentication",
        "domain": null,
        "challenge": "custom_challenge_12345",
        "services": null
      },
      "expected_output": {
        "did_document_has_proof": true,
        "proof_challenge": "custom_challenge_12345"
      },
      "assertions": [
        "result.did_document['proof']['challenge'] == 'custom_challenge_12345'"
      ]
    },
    {
      "id": "TC-007",
      "name": "创建 DID 身份 - 带自定义服务",
      "scene": "DID 身份创建",
      "description": "创建带自定义服务列表的 DID 身份",
      "input": {
        "hostname": "awiki.ai",
        "path_prefix": ["user"],
        "proof_purpose": "authentication",
        "domain": null,
        "challenge": null,
        "services": [
          {
            "id": "#messaging",
            "type": "MessagingService",
            "serviceEndpoint": "https://awiki.ai/messaging"
          },
          {
            "id": "did:wba:awiki.ai:user:k1_test#profile",
            "type": "ProfileService",
            "serviceEndpoint": "https://awiki.ai/profile"
          }
        ]
      },
      "expected_output": {
        "did_document_has_services": true,
        "services_count": 2
      },
      "assertions": [
        "result.did_document['service'] 长度为 2",
        "result.did_document['service'][0]['id'] == 'did:wba:awiki.ai:user:k1_<fp>#messaging'",
        "result.did_document['service'][1]['id'] == 'did:wba:awiki.ai:user:k1_test#profile'"
      ]
    },
    {
      "id": "TC-008",
      "name": "创建 DID 身份 - 带 E2EE 密钥",
      "scene": "密钥对生成",
      "description": "验证创建的身份包含完整的 E2EE 密钥对（key-2 secp256r1 签名 + key-3 X25519 协议）",
      "input": {
        "hostname": "awiki.ai",
        "path_prefix": ["user"],
        "proof_purpose": "authentication",
        "domain": null,
        "challenge": null,
        "services": null
      },
      "expected_output": {
        "key_1_present": true,
        "key_2_present": true,
        "key_3_present": true
      },
      "assertions": [
        "result.private_key_pem 非 None (key-1 secp256k1)",
        "result.public_key_pem 非 None (key-1 secp256k1)",
        "result.e2ee_signing_private_pem 非 None (key-2 secp256r1)",
        "result.e2ee_signing_public_pem 非 None (key-2 secp256r1)",
        "result.e2ee_agreement_private_pem 非 None (key-3 X25519)",
        "result.e2ee_agreement_public_pem 非 None (key-3 X25519)"
      ]
    },
    {
      "id": "TC-009",
      "name": "DIDIdentity.unique_id 属性",
      "scene": "DID 文档生成",
      "description": "验证 unique_id 属性正确提取 DID 最后一段路径",
      "input": {
        "did": "did:wba:awiki.ai:user:k1_AB8G0We3oboQNZldVTWdfTyqSrwQPV7QSCSeP3P8O1g"
      },
      "expected_output": {
        "unique_id": "k1_AB8G0We3oboQNZldVTWdfTyqSrwQPV7QSCSeP3P8O1g"
      },
      "assertions": [
        "identity.unique_id == 'k1_AB8G0We3oboQNZldVTWdfTyqSrwQPV7QSCSeP3P8O1g'"
      ]
    },
    {
      "id": "TC-010",
      "name": "DIDIdentity.get_private_key() 方法",
      "scene": "私钥加载",
      "description": "验证从 PEM 字节加载 secp256k1 私钥对象",
      "input": {
        "private_key_pem": "<bytes from create_identity>"
      },
      "expected_output": {
        "key_type": "ec.EllipticCurvePrivateKey",
        "key_curve": "secp256k1"
      },
      "assertions": [
        "isinstance(result, ec.EllipticCurvePrivateKey)",
        "result.curve.name == 'secp256k1'"
      ]
    },
    {
      "id": "TC-011",
      "name": "load_private_key() 函数 - 有效 PEM",
      "scene": "私钥加载",
      "description": "使用有效的 secp256k1 PEM 字节加载私钥对象",
      "input": {
        "pem_bytes": "<valid secp256k1 PEM bytes>"
      },
      "expected_output": {
        "key_type": "ec.EllipticCurvePrivateKey"
      },
      "assertions": [
        "isinstance(result, ec.EllipticCurvePrivateKey)",
        "result 可用于签名操作"
      ]
    },
    {
      "id": "TC-012",
      "name": "load_private_key() 函数 - 无效 PEM",
      "scene": "私钥加载",
      "description": "使用无效的 PEM 数据应抛出异常",
      "input": {
        "pem_bytes": "b'invalid pem data'"
      },
      "expected_output": {
        "exception": "ValueError 或 cryptography 异常"
      },
      "assertions": [
        "调用 load_private_key(invalid_pem) 抛出异常"
      ]
    },
    {
      "id": "TC-013",
      "name": "load_private_key() 函数 - 非椭圆曲线密钥",
      "scene": "私钥加载",
      "description": "使用非椭圆曲线密钥 PEM 应抛出 TypeError",
      "input": {
        "pem_bytes": "<RSA private key PEM bytes>"
      },
      "expected_output": {
        "exception": "TypeError"
      },
      "assertions": [
        "调用 load_private_key(rsa_pem) 抛出 TypeError",
        "错误消息包含 'Expected EllipticCurvePrivateKey'"
      ]
    },
    {
      "id": "TC-014",
      "name": "DIDIdentity 数据类 - 完整字段初始化",
      "scene": "DID 身份创建",
      "description": "验证 DIDIdentity 所有字段正确初始化",
      "input": {
        "did": "did:wba:awiki.ai:user:k1_test",
        "did_document": {"id": "did:wba:awiki.ai:user:k1_test"},
        "private_key_pem": b"-----BEGIN EC PRIVATE KEY-----...",
        "public_key_pem": b"-----BEGIN PUBLIC KEY-----..."
      },
      "expected_output": {
        "user_id": null,
        "jwt_token": null,
        "e2ee_signing_private_pem": null,
        "e2ee_agreement_private_pem": null
      },
      "assertions": [
        "identity.did == 'did:wba:awiki.ai:user:k1_test'",
        "identity.user_id is None",
        "identity.jwt_token is None"
      ]
    },
    {
      "id": "TC-015",
      "name": "DIDIdentity 数据类 - 注册后更新字段",
      "scene": "DID 身份创建",
      "description": "验证注册后可更新 user_id 和 jwt_token 字段",
      "input": {
        "identity": "<DIDIdentity instance>",
        "user_id": "77ec3f44-f94f-4c19-b315-49c0f0bf4a37",
        "jwt_token": "eyJhbGciOiJFUzI1NksiLCJ0eXAiOiJKV1QifQ..."
      },
      "expected_output": {
        "user_id": "77ec3f44-f94f-4c19-b315-49c0f0bf4a37",
        "jwt_token": "eyJhbGciOiJFUzI1NksiLCJ0eXAiOiJKV1QifQ..."
      },
      "assertions": [
        "identity.user_id == '77ec3f44-f94f-4c19-b315-49c0f0bf4a37'",
        "identity.jwt_token == 'eyJhbGciOiJFUzI1NksiLCJ0eXAiOiJKV1QifQ...'"
      ]
    },
    {
      "id": "TC-016",
      "name": "create_identity() - 空路径前缀",
      "scene": "DID 身份创建",
      "description": "使用空路径前缀创建 DID 身份",
      "input": {
        "hostname": "awiki.ai",
        "path_prefix": [],
        "proof_purpose": "authentication",
        "domain": null,
        "challenge": null,
        "services": null
      },
      "expected_output": {
        "did_format": "did:wba:awiki.ai:k1_<fingerprint>"
      },
      "assertions": [
        "result.did 以 'did:wba:awiki.ai:k1_' 开头"
      ]
    },
    {
      "id": "TC-017",
      "name": "create_identity() - 多级路径前缀",
      "scene": "DID 身份创建",
      "description": "使用多级路径前缀创建 DID 身份",
      "input": {
        "hostname": "awiki.ai",
        "path_prefix": ["org", "department", "user"],
        "proof_purpose": "authentication",
        "domain": null,
        "challenge": null,
        "services": null
      },
      "expected_output": {
        "did_format": "did:wba:awiki.ai:org:department:user:k1_<fingerprint>"
      },
      "assertions": [
        "result.did 包含 'org:department:user'"
      ]
    },
    {
      "id": "TC-018",
      "name": "create_identity() - 自动生成 challenge",
      "scene": "DID 身份创建",
      "description": "验证未提供 challenge 时自动生成随机值",
      "input": {
        "hostname": "awiki.ai",
        "path_prefix": ["user"],
        "proof_purpose": "authentication",
        "domain": null,
        "challenge": null,
        "services": null
      },
      "expected_output": {
        "challenge_length": 32,
        "challenge_format": "hex"
      },
      "assertions": [
        "result.did_document['proof']['challenge'] 长度为 32",
        "result.did_document['proof']['challenge'] 是有效的 hex 字符串"
      ]
    },
    {
      "id": "TC-019",
      "name": "create_identity() - 多次调用生成不同身份",
      "scene": "密钥对生成",
      "description": "验证多次调用 create_identity() 生成不同的密钥对和 DID",
      "input": {
        "call_count": 3,
        "hostname": "awiki.ai",
        "path_prefix": ["user"]
      },
      "expected_output": {
        "unique_dids": 3,
        "unique_keys": 3
      },
      "assertions": [
        "3 次调用生成的 result.did 互不相同",
        "3 次调用生成的 result.private_key_pem 互不相同",
        "3 次调用生成的 result.public_key_pem 互不相同"
      ]
    },
    {
      "id": "TC-020",
      "name": "create_identity() - 服务 ID 自动添加 DID 前缀",
      "scene": "DID 文档生成",
      "description": "验证服务 ID 以 '#' 开头时自动添加 DID 前缀",
      "input": {
        "hostname": "awiki.ai",
        "path_prefix": ["user"],
        "services": [
          {"id": "#endpoint1", "type": "TestService", "serviceEndpoint": "https://test.com/1"},
          {"id": "#endpoint2", "type": "TestService", "serviceEndpoint": "https://test.com/2"}
        ]
      },
      "expected_output": {
        "service_ids_prefixed": true
      },
      "assertions": [
        "result.did_document['service'][0]['id'] 以 result.did + '#endpoint1' 结尾",
        "result.did_document['service'][1]['id'] 以 result.did + '#endpoint2' 结尾"
      ]
    }
  ],
  "coverage": {
    "scenes": [
      {
        "name": "DID 身份创建",
        "test_cases": ["TC-001", "TC-002", "TC-003", "TC-004", "TC-005", "TC-006", "TC-007", "TC-014", "TC-015", "TC-016", "TC-017", "TC-018"],
        "description": "覆盖 hostname、path_prefix、proof_purpose、domain、challenge、services 等参数组合"
      },
      {
        "name": "密钥对生成",
        "test_cases": ["TC-008", "TC-019"],
        "description": "覆盖 key-1(secp256k1)、key-2(secp256r1)、key-3(X25519) 密钥对生成及唯一性验证"
      },
      {
        "name": "DID 文档生成",
        "test_cases": ["TC-009", "TC-020"],
        "description": "覆盖 DID 文档结构、服务列表、proof 字段验证"
      },
      {
        "name": "私钥加载",
        "test_cases": ["TC-010", "TC-011", "TC-012", "TC-013"],
        "description": "覆盖有效 PEM 加载、无效 PEM 异常处理、非椭圆曲线密钥类型检查"
      }
    ],
    "functions": {
      "create_identity": ["TC-001", "TC-002", "TC-003", "TC-004", "TC-005", "TC-006", "TC-007", "TC-008", "TC-016", "TC-017", "TC-018", "TC-019", "TC-020"],
      "load_private_key": ["TC-011", "TC-012", "TC-013"],
      "DIDIdentity": ["TC-009", "TC-010", "TC-014", "TC-015"]
    },
    "total_test_cases": 20
  },
  "metadata": {
    "created_date": "2026-03-16",
    "module_version": "基于 ANP create_did_wba_document_with_key_binding()",
    "test_framework": "pytest",
    "dependencies": [
      "cryptography",
      "anp"
    ]
  }
}
