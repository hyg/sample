{
  "module": "python/scripts/utils/logging_config.py",
  "description": "应用日志工具 - 每日文件轮转与保留策略",
  "business_scenarios": [
    {
      "id": "SC001",
      "name": "日志目录管理",
      "description": "获取并创建日志目录 <DATA_DIR>/logs",
      "functions": ["get_log_dir"]
    },
    {
      "id": "SC002",
      "name": "日志文件路径生成",
      "description": "根据日期生成每日日志文件路径",
      "functions": ["get_log_file_path", "_extract_log_date"]
    },
    {
      "id": "SC003",
      "name": "日志文件列表管理",
      "description": "列出和管理已存在的日志文件",
      "functions": ["_list_managed_log_files", "find_latest_log_file"]
    },
    {
      "id": "SC004",
      "name": "日志清理策略",
      "description": "基于时间和大小的双重清理策略",
      "functions": ["cleanup_log_files"]
    },
    {
      "id": "SC005",
      "name": "每日日志文件处理器",
      "description": "自动轮转的日志文件处理器",
      "functions": ["DailyRetentionFileHandler"]
    },
    {
      "id": "SC006",
      "name": "日志系统配置",
      "description": "配置根日志记录器和标准输出镜像",
      "functions": ["configure_logging", "_configure_stdio_mirroring"]
    }
  ],
  "test_cases": [
    {
      "id": "TC001",
      "scenario": "SC001",
      "name": "get_log_dir - 默认配置创建日志目录",
      "description": "使用默认 SDKConfig 创建日志目录",
      "precondition": "数据目录不存在 logs 子目录",
      "input": {
        "config": null
      },
      "expected_output": {
        "return_type": "Path",
        "path_suffix": "/logs",
        "directory_created": true
      },
      "assertions": [
        "返回路径以 /logs 结尾",
        "目录被创建（如果不存在）",
        "路径是绝对路径"
      ]
    },
    {
      "id": "TC002",
      "scenario": "SC001",
      "name": "get_log_dir - 自定义配置",
      "description": "使用自定义 SDKConfig 创建日志目录",
      "precondition": "提供自定义 data_dir 配置",
      "input": {
        "config": "SDKConfig(data_dir=Path('/custom/path'))"
      },
      "expected_output": {
        "return_type": "Path",
        "path_suffix": "/custom/path/logs",
        "directory_created": true
      },
      "assertions": [
        "返回路径包含自定义 data_dir",
        "目录被创建"
      ]
    },
    {
      "id": "TC003",
      "scenario": "SC001",
      "name": "get_log_dir - 目录已存在",
      "description": "日志目录已存在时不报错",
      "precondition": "logs 目录已存在",
      "input": {
        "config": null
      },
      "expected_output": {
        "return_type": "Path",
        "directory_created": false
      },
      "assertions": [
        "返回现有目录路径",
        "不抛出异常",
        "exist_ok=True 生效"
      ]
    },
    {
      "id": "TC004",
      "scenario": "SC002",
      "name": "get_log_file_path - 默认日期生成路径",
      "description": "使用当前日期生成日志文件路径",
      "precondition": "日志目录存在",
      "input": {
        "log_dir": "Path('/tmp/logs')",
        "now": null,
        "prefix": "awiki-agent"
      },
      "expected_output": {
        "return_type": "Path",
        "filename_pattern": "awiki-agent-YYYY-MM-DD.log"
      },
      "assertions": [
        "文件名包含 awiki-agent 前缀",
        "文件名包含 ISO 格式日期",
        "文件扩展名为 .log"
      ]
    },
    {
      "id": "TC005",
      "scenario": "SC002",
      "name": "get_log_file_path - 指定日期",
      "description": "使用指定日期生成日志文件路径",
      "precondition": "日志目录存在",
      "input": {
        "log_dir": "Path('/tmp/logs')",
        "now": "datetime(2026, 3, 16, 10, 30, 0)",
        "prefix": "awiki-agent"
      },
      "expected_output": {
        "return_type": "Path",
        "filename": "awiki-agent-2026-03-16.log"
      },
      "assertions": [
        "文件名日期与指定日期一致",
        "忽略时间部分，只使用日期"
      ]
    },
    {
      "id": "TC006",
      "scenario": "SC002",
      "name": "get_log_file_path - 自定义前缀",
      "description": "使用自定义前缀生成日志文件路径",
      "precondition": "日志目录存在",
      "input": {
        "log_dir": "Path('/tmp/logs')",
        "now": "datetime(2026, 3, 16)",
        "prefix": "custom-prefix"
      },
      "expected_output": {
        "return_type": "Path",
        "filename": "custom-prefix-2026-03-16.log"
      },
      "assertions": [
        "文件名使用自定义前缀"
      ]
    },
    {
      "id": "TC007",
      "scenario": "SC002",
      "name": "_extract_log_date - 有效文件名",
      "description": "从有效日志文件名提取日期",
      "precondition": "文件存在且命名正确",
      "input": {
        "path": "Path('awiki-agent-2026-03-16.log')",
        "prefix": "awiki-agent"
      },
      "expected_output": {
        "return_type": "date",
        "value": "date(2026, 3, 16)"
      },
      "assertions": [
        "正确解析 ISO 日期格式",
        "返回 date 对象"
      ]
    },
    {
      "id": "TC008",
      "scenario": "SC002",
      "name": "_extract_log_date - 无效前缀",
      "description": "前缀不匹配返回 None",
      "precondition": "文件存在但前缀不匹配",
      "input": {
        "path": "Path('other-2026-03-16.log')",
        "prefix": "awiki-agent"
      },
      "expected_output": {
        "return_type": "None"
      },
      "assertions": [
        "返回 None"
      ]
    },
    {
      "id": "TC009",
      "scenario": "SC002",
      "name": "_extract_log_date - 无效扩展名",
      "description": "扩展名不是 .log 返回 None",
      "precondition": "文件扩展名错误",
      "input": {
        "path": "Path('awiki-agent-2026-03-16.txt')",
        "prefix": "awiki-agent"
      },
      "expected_output": {
        "return_type": "None"
      },
      "assertions": [
        "返回 None"
      ]
    },
    {
      "id": "TC010",
      "scenario": "SC002",
      "name": "_extract_log_date - 无效日期格式",
      "description": "日期格式无效返回 None",
      "precondition": "日期字符串格式错误",
      "input": {
        "path": "Path('awiki-agent-invalid-date.log')",
        "prefix": "awiki-agent"
      },
      "expected_output": {
        "return_type": "None"
      },
      "assertions": [
        "捕获 ValueError",
        "返回 None"
      ]
    },
    {
      "id": "TC011",
      "scenario": "SC002",
      "name": "_extract_log_date - 非文件路径",
      "description": "路径不是文件返回 None",
      "precondition": "路径不存在或是目录",
      "input": {
        "path": "Path('/nonexistent/file.log')",
        "prefix": "awiki-agent"
      },
      "expected_output": {
        "return_type": "None"
      },
      "assertions": [
        "is_file() 检查生效",
        "返回 None"
      ]
    },
    {
      "id": "TC012",
      "scenario": "SC003",
      "name": "_list_managed_log_files - 空目录",
      "description": "目录中没有日志文件",
      "precondition": "日志目录为空",
      "input": {
        "log_dir": "Path('/tmp/empty_logs')",
        "prefix": "awiki-agent"
      },
      "expected_output": {
        "return_type": "list",
        "value": []
      },
      "assertions": [
        "返回空列表"
      ]
    },
    {
      "id": "TC013",
      "scenario": "SC003",
      "name": "_list_managed_log_files - 多个文件排序",
      "description": "多个日志文件按日期升序排列",
      "precondition": "目录中有多个日志文件",
      "input": {
        "log_dir": "Path('/tmp/logs')",
        "prefix": "awiki-agent",
        "existing_files": [
          "awiki-agent-2026-03-18.log",
          "awiki-agent-2026-03-15.log",
          "awiki-agent-2026-03-17.log"
        ]
      },
      "expected_output": {
        "return_type": "list",
        "order": [
          "awiki-agent-2026-03-15.log",
          "awiki-agent-2026-03-17.log",
          "awiki-agent-2026-03-18.log"
        ]
      },
      "assertions": [
        "文件按日期升序排列",
        "只返回匹配的日志文件"
      ]
    },
    {
      "id": "TC014",
      "scenario": "SC003",
      "name": "_list_managed_log_files - 过滤非管理文件",
      "description": "忽略不符合命名规则的文件",
      "precondition": "目录中有混合文件",
      "input": {
        "log_dir": "Path('/tmp/logs')",
        "prefix": "awiki-agent",
        "existing_files": [
          "awiki-agent-2026-03-16.log",
          "other.log",
          "awiki-agent-temp.txt",
          "awiki-agent-invalid.log"
        ]
      },
      "expected_output": {
        "return_type": "list",
        "count": 1,
        "files": ["awiki-agent-2026-03-16.log"]
      },
      "assertions": [
        "只返回有效命名的日志文件",
        "过滤无效日期格式文件"
      ]
    },
    {
      "id": "TC015",
      "scenario": "SC003",
      "name": "find_latest_log_file - 存在日志文件",
      "description": "找到最新的日志文件",
      "precondition": "目录中有多个日志文件",
      "input": {
        "log_dir": "Path('/tmp/logs')",
        "prefix": "awiki-agent",
        "existing_files": [
          "awiki-agent-2026-03-15.log",
          "awiki-agent-2026-03-16.log"
        ]
      },
      "expected_output": {
        "return_type": "Path",
        "filename": "awiki-agent-2026-03-16.log"
      },
      "assertions": [
        "返回日期最新的文件"
      ]
    },
    {
      "id": "TC016",
      "scenario": "SC003",
      "name": "find_latest_log_file - 无日志文件",
      "description": "目录中没有日志文件返回 None",
      "precondition": "日志目录为空",
      "input": {
        "log_dir": "Path('/tmp/empty_logs')",
        "prefix": "awiki-agent"
      },
      "expected_output": {
        "return_type": "None"
      },
      "assertions": [
        "返回 None"
      ]
    },
    {
      "id": "TC017",
      "scenario": "SC004",
      "name": "cleanup_log_files - 无过期文件",
      "description": "没有超过保留期限的文件",
      "precondition": "所有文件都在保留期内",
      "input": {
        "log_dir": "Path('/tmp/logs')",
        "now": "datetime(2026, 3, 16)",
        "max_retention_days": 15,
        "existing_files": ["awiki-agent-2026-03-10.log"]
      },
      "expected_output": {
        "return_type": "list",
        "deleted_count": 0
      },
      "assertions": [
        "没有文件被删除",
        "返回空列表"
      ]
    },
    {
      "id": "TC018",
      "scenario": "SC004",
      "name": "cleanup_log_files - 删除过期文件",
      "description": "删除超过保留期限的文件",
      "precondition": "存在超过 15 天的文件",
      "input": {
        "log_dir": "Path('/tmp/logs')",
        "now": "datetime(2026, 3, 16)",
        "max_retention_days": 15,
        "existing_files": [
          "awiki-agent-2026-02-01.log",
          "awiki-agent-2026-03-15.log"
        ]
      },
      "expected_output": {
        "return_type": "list",
        "deleted_files": ["awiki-agent-2026-02-01.log"],
        "deleted_count": 1
      },
      "assertions": [
        "过期文件被删除",
        "返回被删除文件列表"
      ]
    },
    {
      "id": "TC019",
      "scenario": "SC004",
      "name": "cleanup_log_files - 大小限制清理",
      "description": "总大小超过限制时删除最旧文件",
      "precondition": "文件总大小超过 15MB，但都在保留期内",
      "input": {
        "log_dir": "Path('/tmp/logs')",
        "now": "datetime(2026, 3, 16)",
        "max_retention_days": 15,
        "max_total_size_bytes": 100,
        "existing_files": [
          {"name": "awiki-agent-2026-03-14.log", "size": 60},
          {"name": "awiki-agent-2026-03-15.log", "size": 60},
          {"name": "awiki-agent-2026-03-16.log", "size": 60}
        ]
      },
      "expected_output": {
        "return_type": "list",
        "deleted_count": 2,
        "remaining_files": ["awiki-agent-2026-03-16.log"]
      },
      "assertions": [
        "从最旧文件开始删除",
        "至少保留一个最新文件",
        "总大小降至限制以下"
      ]
    },
    {
      "id": "TC020",
      "scenario": "SC004",
      "name": "cleanup_log_files - 保留边界值",
      "description": "保留期限边界值测试（第 15 天）",
      "precondition": "文件正好在保留期边界",
      "input": {
        "log_dir": "Path('/tmp/logs')",
        "now": "datetime(2026, 3, 16)",
        "max_retention_days": 15,
        "existing_files": [
          "awiki-agent-2026-03-02.log",
          "awiki-agent-2026-03-03.log"
        ]
      },
      "expected_output": {
        "deleted_files": ["awiki-agent-2026-03-02.log"],
        "kept_files": ["awiki-agent-2026-03-03.log"]
      },
      "assertions": [
        "keep_after = current.date() - timedelta(days=14)",
        "3 月 2 日被删除（第 15 天前）",
        "3 月 3 日被保留（第 14 天）"
      ]
    },
    {
      "id": "TC021",
      "scenario": "SC004",
      "name": "cleanup_log_files - 文件不存在处理",
      "description": "清理过程中文件被外部删除",
      "precondition": "文件在列出后、删除前被移除",
      "input": {
        "log_dir": "Path('/tmp/logs')",
        "now": "datetime(2026, 3, 16)",
        "max_retention_days": 15,
        "race_condition": true
      },
      "expected_output": {
        "return_type": "list",
        "exception_handled": true
      },
      "assertions": [
        "捕获 FileNotFoundError",
        "不抛出异常",
        "继续处理其他文件"
      ]
    },
    {
      "id": "TC022",
      "scenario": "SC004",
      "name": "cleanup_log_files - 自动创建目录",
      "description": "日志目录不存在时自动创建",
      "precondition": "日志目录不存在",
      "input": {
        "log_dir": "Path('/tmp/new_logs')",
        "now": "datetime(2026, 3, 16)"
      },
      "expected_output": {
        "directory_created": true,
        "deleted_count": 0
      },
      "assertions": [
        "目录被创建",
        "不抛出异常"
      ]
    },
    {
      "id": "TC023",
      "scenario": "SC005",
      "name": "DailyRetentionFileHandler - 初始化创建文件",
      "description": "处理器初始化时创建当日日志文件",
      "precondition": "日志目录存在",
      "input": {
        "log_dir": "Path('/tmp/logs')",
        "prefix": "awiki-agent",
        "clock": "lambda: datetime(2026, 3, 16, 10, 0, 0)"
      },
      "expected_output": {
        "current_path": "Path('/tmp/logs/awiki-agent-2026-03-16.log')",
        "file_created": true
      },
      "assertions": [
        "current_path 指向当日文件",
        "文件被创建",
        "执行一次清理"
      ]
    },
    {
      "id": "TC024",
      "scenario": "SC005",
      "name": "DailyRetentionFileHandler - emit 写入日志",
      "description": "写入日志记录到文件",
      "precondition": "处理器已初始化",
      "input": {
        "record": "LogRecord(level=INFO, msg='Test message')"
      },
      "expected_output": {
        "file_content_contains": "[INFO] Test message"
      },
      "assertions": [
        "消息被写入文件",
        "使用配置的格式",
        "调用 flush()"
      ]
    },
    {
      "id": "TC025",
      "scenario": "SC005",
      "name": "DailyRetentionFileHandler - 跨天轮转",
      "description": "日期变化时切换到新文件",
      "precondition": "处理器已初始化，时钟跨天",
      "input": {
        "initial_clock": "datetime(2026, 3, 16, 23, 59, 59)",
        "later_clock": "datetime(2026, 3, 17, 0, 0, 1)"
      },
      "expected_output": {
        "old_file": "awiki-agent-2026-03-16.log",
        "new_file": "awiki-agent-2026-03-17.log",
        "old_file_closed": true
      },
      "assertions": [
        "检测到日期变化",
        "关闭旧文件",
        "打开新文件"
      ]
    },
    {
      "id": "TC026",
      "scenario": "SC005",
      "name": "DailyRetentionFileHandler - 定期清理",
      "description": "达到清理间隔时执行清理",
      "precondition": "处理器运行中，达到清理间隔",
      "input": {
        "cleanup_interval_seconds": 60,
        "elapsed_seconds": 61
      },
      "expected_output": {
        "cleanup_executed": true
      },
      "assertions": [
        "检查是否需要清理",
        "达到间隔时执行 cleanup_log_files",
        "更新下次清理时间"
      ]
    },
    {
      "id": "TC027",
      "scenario": "SC005",
      "name": "DailyRetentionFileHandler - flush 刷新缓冲区",
      "description": "刷新文件缓冲区到磁盘",
      "precondition": "有未刷新的写入",
      "input": {},
      "expected_output": {
        "stream_flushed": true
      },
      "assertions": [
        "调用 stream.flush()",
        "数据写入磁盘"
      ]
    },
    {
      "id": "TC028",
      "scenario": "SC005",
      "name": "DailyRetentionFileHandler - close 关闭处理器",
      "description": "关闭文件流和处理器",
      "precondition": "处理器已初始化",
      "input": {},
      "expected_output": {
        "stream_closed": true,
        "current_path": null
      },
      "assertions": [
        "文件流被关闭",
        "current_path 置为 None",
        "调用父类 close()"
      ]
    },
    {
      "id": "TC029",
      "scenario": "SC005",
      "name": "DailyRetentionFileHandler - 线程安全",
      "description": "emit 方法使用锁保护",
      "precondition": "多线程并发写入",
      "input": {
        "threads": 10,
        "records_per_thread": 100
      },
      "expected_output": {
        "no_data_corruption": true,
        "all_records_written": true
      },
      "assertions": [
        "使用 acquire()/release() 保护",
        "无数据损坏",
        "无竞态条件"
      ]
    },
    {
      "id": "TC030",
      "scenario": "SC005",
      "name": "DailyRetentionFileHandler - 异常处理",
      "description": "emit 异常时调用 handleError",
      "precondition": "写入时发生异常",
      "input": {
        "simulate_error": "stream.write raises IOError"
      },
      "expected_output": {
        "handleError_called": true,
        "no_crash": true
      },
      "assertions": [
        "捕获异常",
        "调用 handleError",
        "不崩溃"
      ]
    },
    {
      "id": "TC031",
      "scenario": "SC005",
      "name": "DailyRetentionFileHandler - 自定义保留配置",
      "description": "使用自定义保留参数初始化",
      "precondition": "无",
      "input": {
        "max_retention_days": 30,
        "max_total_size_bytes": 50 * 1024 * 1024,
        "cleanup_interval_seconds": 120
      },
      "expected_output": {
        "retention_days": 30,
        "max_size_bytes": 52428800,
        "cleanup_interval": 120
      },
      "assertions": [
        "参数被正确存储",
        "清理策略使用自定义值"
      ]
    },
    {
      "id": "TC032",
      "scenario": "SC006",
      "name": "configure_logging - 首次配置",
      "description": "首次配置日志系统",
      "precondition": "根日志记录器无处理器",
      "input": {
        "level": "logging.INFO",
        "console_level": "logging.INFO",
        "force": false
      },
      "expected_output": {
        "file_handler_added": true,
        "console_handler_added": true,
        "log_file_path": "Path"
      },
      "assertions": [
        "添加文件处理器",
        "添加控制台处理器",
        "返回日志文件路径"
      ]
    },
    {
      "id": "TC033",
      "scenario": "SC006",
      "name": "configure_logging - 重复配置不添加",
      "description": "已配置时不重复添加处理器",
      "precondition": "根日志记录器已有处理器",
      "input": {
        "force": false
      },
      "expected_output": {
        "handler_count_unchanged": true
      },
      "assertions": [
        "不创建新处理器",
        "使用现有处理器"
      ]
    },
    {
      "id": "TC034",
      "scenario": "SC006",
      "name": "configure_logging - force 强制重新配置",
      "description": "强制模式移除现有处理器",
