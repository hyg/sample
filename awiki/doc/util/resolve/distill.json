        }
      },
      "mock_response": {
        "status_code": 200,
        "json": {
          "status": "active",
          "did": "did:wba:awiki.test:user:k1_bob456"
        }
      },
      "expected_output": {
        "return": "did:wba:awiki.test:user:k1_bob456",
        "http_call": true,
        "url": "https://awiki.test/user-service/.well-known/handle/bob"
      },
      "assertion": "自动剥离 awiki.test 后缀"
    },
    {
      "id": "TC007",
      "name": "域名后缀处理 - 自定义 did_domain",
      "category": "域名后缀处理",
      "input": {
        "identifier": "charlie.custom.domain",
        "config": {
          "user_service_url": "https://custom.domain",
