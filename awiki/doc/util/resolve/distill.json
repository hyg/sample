{
  "module": "python/scripts/utils/resolve.py",
  "function": "resolve_to_did",
  "description": "Handle-to-DID 解析工具，通过 .well-known/handle 端点将 handle 转换为 DID",
  "test_cases": [
    {
      "id": "TC001",
      "name": "DID 直接返回 - 标准 did:wba 格式",
      "category": "DID 直接返回",
      "input": {
        "identifier": "did:wba:awiki.ai:user:k1_AB8G0We3oboQNZldVTWdfTyqSrwQPV7QSCSeP3P8O1g",
        "config": null
      },
      "expected_output": {
        "return": "did:wba:awiki.ai:user:k1_AB8G0We3oboQNZldVTWdfTyqSrwQPV7QSCSeP3P8O1g",
        "http_call": false
      },
      "assertion": "identifier 以 'did:' 开头，直接返回，不发起 HTTP 请求"
    },
    {
      "id": "TC002",
      "name": "DID 直接返回 - 其他 DID 方法",
      "category": "DID 直接返回",
      "input": {
        "identifier": "did:ethr:0x1234567890abcdef1234567890abcdef12345678",
        "config": null
      },
      "expected_output": {
        "return": "did:ethr:0x1234567890abcdef1234567890abcdef12345678",
        "http_call": false
      },
      "assertion": "任何以 'did:' 开头的标识符都直接返回"
    },
    {
      "id": "TC003",
      "name": "DID 直接返回 - DID 包含路径",
      "category": "DID 直接返回",
      "input": {
        "identifier": "did:wba:awiki.ai:user:k1_test#key-1",
        "config": null
      },
      "expected_output": {
        "return": "did:wba:awiki.ai:user:k1_test#key-1",
        "http_call": false
      },
      "assertion": "DID 包含片段标识符也直接返回"
    },
    {
      "id": "TC004",
      "name": "Handle 解析 - 成功返回 active DID",
      "category": "Handle 解析为 DID",
      "input": {
        "identifier": "alice",
        "config": {
          "user_service_url": "https://awiki.ai",
          "did_domain": null
        }
      },
      "mock_response": {
        "status_code": 200,
        "json": {
          "status": "active",
          "did": "did:wba:awiki.ai:user:k1_alice123"
        }
      },
      "expected_output": {
        "return": "did:wba:awiki.ai:user:k1_alice123",
        "http_call": true,
        "url": "https://awiki.ai/user-service/.well-known/handle/alice"
      },
      "assertion": "handle 解析成功，返回响应的 DID"
    },
    {
      "id": "TC005",
      "name": "Handle 解析 - 带域名后缀自动剥离",
      "category": "域名后缀处理",
      "input": {
        "identifier": "alice.awiki.ai",
        "config": {
          "user_service_url": "https://awiki.ai",
          "did_domain": null
        }
      },
      "mock_response": {
        "status_code": 200,
        "json": {
          "status": "active",
          "did": "did:wba:awiki.ai:user:k1_alice123"
        }
      },
      "expected_output": {
        "return": "did:wba:awiki.ai:user:k1_alice123",
        "http_call": true,
        "url": "https://awiki.ai/user-service/.well-known/handle/alice"
      },
      "assertion": "自动剥离 awiki.ai 后缀，使用剥离后的 handle 请求"
    },
