    {
      "id": "WS-009",
      "category": "JSON-RPC 请求",
      "scenario": "发送 JSON-RPC 请求并获取响应",
      "method": "send_rpc",
      "precondition": "已建立 WebSocket 连接",
      "input": {
        "method": "test.method",
        "params": {"key": "value"}
      },
      "expected_output": {
        "request_sent": {
          "jsonrpc": "2.0",
          "method": "test.method",
          "id": 1,
          "params": {"key": "value"}
        },
        "result": {"data": "response_data"}
      },
      "assertions": [
        "请求包含正确的 jsonrpc 版本",
        "请求 ID 自增",
        "返回 result 字段内容"
      ]
    },
    {
      "id": "WS-010",
      "category": "JSON-RPC 请求",
      "scenario": "未连接时发送 RPC 应失败",
      "method": "send_rpc",
      "precondition": "未建立连接",
      "input": {
        "self._conn": null,
        "method": "test.method"
      },
      "expected_output": {
        "error": "RuntimeError: WebSocket not connected"
      },
      "assertions": [
        "抛出 RuntimeError 异常",
        "异常消息包含 'not connected'"
      ]
    },
    {
      "id": "WS-011",
      "category": "JSON-RPC 请求",
      "scenario": "处理 JSON-RPC 错误响应",
      "method": "send_rpc",
      "precondition": "已建立连接，服务器返回错误",
      "input": {
        "method": "test.method",
        "server_response": {
          "jsonrpc": "2.0",
          "id": 1,
          "error": {"code": -32000, "message": "Method not found"}
        }
      },
      "expected_output": {
        "error": "RuntimeError: JSON-RPC error -32000: Method not found"
      },
      "assertions": [
        "抛出 RuntimeError 异常",
        "异常消息包含错误代码和消息"
      ]
    },
    {
      "id": "WS-012",
      "category": "JSON-RPC 请求",
      "scenario": "跳过推送通知获取正确响应",
      "method": "send_rpc",
      "precondition": "已建立连接，期间收到推送通知",
      "input": {
        "method": "test.method",
        "intermediate_messages": [
          {"jsonrpc": "2.0", "method": "notification", "params": {"type": "push"}}
        ],
        "server_response": {
          "jsonrpc": "2.0",
          "id": 1,
          "result": {"data": "response"}
        }
      },
      "expected_output": {
        "result": {"data": "response"}
      },
      "assertions": [
        "跳过无 id 字段的通知",
        "匹配正确的请求 ID",
        "返回目标响应"
      ]
    },
    {
      "id": "WS-013",
      "category": "JSON-RPC 请求",
      "scenario": "请求 ID 自增机制",
      "method": "send_rpc",
      "precondition": "已建立连接，多次调用",
      "input": {
        "calls": 3
      },
      "expected_output": {
        "request_ids": [1, 2, 3]
      },
      "assertions": [
        "每次请求 ID 递增",
        "从 1 开始计数"
      ]
    },
    {
