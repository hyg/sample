{
  "file_analyzed": "D:\\huangyg\\git\\sample\\awiki\\python\\scripts\\utils\\ws.py",
  "analysis_date": "2026-03-16",
  "class_name": "WsClient",
  "description": "WebSocket 客户端封装，用于 molt-message WebSocket 端点，支持 JSON-RPC 请求和推送通知",
  "test_cases": [
    {
      "id": "WS-001",
      "category": "WebSocket 连接",
      "scenario": "正常建立 WebSocket 连接",
      "method": "connect",
      "precondition": "SDKConfig 配置正确，DIDIdentity 包含有效 jwt_token",
      "input": {
        "config.molt_message_url": "https://awiki.ai",
        "identity.jwt_token": "valid_jwt_token"
      },
      "expected_output": {
        "connection_status": "connected",
        "ws_url": "wss://awiki.ai/message/ws?token=valid_jwt_token"
      },
      "assertions": [
        "self._conn 不为 None",
        "日志记录连接成功信息"
      ]
    },
    {
      "id": "WS-002",
      "category": "WebSocket 连接",
      "scenario": "JWT token 缺失时连接应失败",
      "method": "connect",
      "precondition": "DIDIdentity 未设置 jwt_token",
      "input": {
        "identity.jwt_token": null
      },
      "expected_output": {
        "error": "ValueError: identity missing jwt_token, call get_jwt_via_wba first"
      },
      "assertions": [
        "抛出 ValueError 异常",
        "异常消息包含 'jwt_token'"
      ]
    },
    {
      "id": "WS-003",
      "category": "WebSocket 连接",
      "scenario": "HTTP URL 自动转换为 WebSocket URL",
      "method": "connect",
      "precondition": "配置使用 HTTP 协议",
      "input": {
        "config.molt_message_url": "http://localhost:8080"
      },
      "expected_output": {
        "ws_url": "ws://localhost:8080/message/ws?token=xxx"
      },
      "assertions": [
        "http:// 被转换为 ws://",
        "https:// 被转换为 wss://"
      ]
    },
    {
      "id": "WS-004",
      "category": "WebSocket 连接",
      "scenario": "已有 ws:// 前缀的 URL 保持不变",
      "method": "connect",
      "precondition": "配置直接使用 WebSocket URL",
      "input": {
        "config.molt_message_ws_url": "ws://localhost:8080"
      },
      "expected_output": {
        "ws_url": "ws://localhost:8080/message/ws?token=xxx"
      },
      "assertions": [
        "URL 前缀保持 ws://",
        "不重复添加协议前缀"
      ]
    },
    {
      "id": "WS-005",
      "category": "WebSocket 连接",
      "scenario": "SSL 配置正确加载",
      "method": "connect",
      "precondition": "使用 HTTPS/WSS 协议",
      "input": {
        "config.molt_message_url": "https://awiki.ai",
        "verify_ssl": true
      },
      "expected_output": {
        "ssl_context": "ssl.SSLContext or True"
      },
      "assertions": [
        "wss:// 连接使用 SSL 上下文",
        "SSL 验证配置正确"
      ]
    },
    {
      "id": "WS-006",
      "category": "连接管理",
      "scenario": "正常关闭连接",
      "method": "close",
      "precondition": "已建立连接",
      "input": {
        "self._conn": "active_connection"
      },
      "expected_output": {
        "self._conn": null
      },
      "assertions": [
        "连接被关闭",
        "self._conn 设置为 None"
      ]
    },
